generator client {
  provider      = "prisma-client-js"
  engineType    = "library"
  previewFeatures = ["partialIndexes"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// =======================
// ENUMS
// =======================

enum Role {
  ADMIN
  EMPLOYEE
}

enum DepartmentStatus {
  ACTIVE
  INACTIVE
}

enum AssetStatus {
  AVAILABLE
  ALLOCATED
  MAINTENANCE
  RETIRED
  DISPOSED
}

enum AssetCondition {
  NEW
  GOOD
  FAIR
  DAMAGED
}

enum TransferStatus {
  PENDING
  APPROVED
  REJECTED
  COMPLETED
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
  REJECTED
}

enum MaintenanceStatus {
  PENDING
  APPROVED
  TECHNICIAN_ASSIGNED
  IN_PROGRESS
  RESOLVED
}

enum MaintenancePriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum AuditVerification {
  VERIFIED
  MISSING
  DAMAGED
}

enum NotificationType {
  ALERT
  APPROVAL
  BOOKING
  TRANSFER
  MAINTENANCE
  AUDIT
  GENERAL
}

// =======================
// MODELS
// =======================

model User {
  id        String    @id @default(uuid())
  email     String    @unique
  password  String
  role         Role      @default(EMPLOYEE)
  refreshToken String?
  tokenVersion Int       @default(0)
  employee     Employee?
  createdAt    DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
}

model Department {
  id        String           @id @default(uuid())
  name      String
  headId    String?
  parentId  String?
  status    DepartmentStatus @default(ACTIVE)
  parent    Department?      @relation("DepartmentHierarchy", fields: [parentId], references: [id])
  children  Department[]     @relation("DepartmentHierarchy")
  employees Employee[]
  assets    Asset[]
  audits    AuditCycle[]
  resources Resource[]
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  deletedAt DateTime?
}

model AssetCategory {
  id        String    @id @default(uuid())
  name      String    @unique
  assets    Asset[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
}

model Employee {
  id                String               @id @default(uuid())
  userId            String               @unique
  user              User                 @relation(fields: [userId], references: [id])
  name              String
  departmentId      String
  department        Department           @relation(fields: [departmentId], references: [id])
  allocations       AssetAllocation[]
  currentAssets     Asset[]              @relation("CurrentAssignee")
  transfersSent     TransferRequest[]    @relation("TransferFrom")
  transfersReceived TransferRequest[]    @relation("TransferTo")
  bookings          ResourceBooking[]
  maintenanceTasks  MaintenanceRequest[] @relation("Technician")
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  deletedAt         DateTime?
}

model Asset {
  id              String               @id @default(uuid())
  assetNumber     String               @unique  // AF-2026-0001
  tag             String               @unique
  name            String
  serialNumber    String?              @unique  // Optional but unique if provided
  manufacturer    String?
  model           String?
  description     String?
  
  categoryId      String
  category        AssetCategory        @relation(fields: [categoryId], references: [id])
  
  departmentId    String
  department      Department           @relation(fields: [departmentId], references: [id])
  
  locationId      String
  location        Location             @relation(fields: [locationId], references: [id])
  
  status          AssetStatus          @default(AVAILABLE)
  condition       AssetCondition       @default(NEW)
  
  purchaseDate    DateTime?
  purchaseCost    Decimal?             @db.Decimal(10, 2)
  warrantyExpiry  DateTime?
  
  qrCode          String?              // Base64 or URL
  
  assigneeId      String?
  currentAssignee Employee?            @relation("CurrentAssignee", fields: [assigneeId], references: [id])
  
  // Relations
  images          AssetImage[]
  documents       AssetDocument[]
  timeline        AssetTimeline[]
  allocations     AssetAllocation[]
  transfers       TransferRequest[]
  maintenance     MaintenanceRequest[]
  auditItems      AuditItem[]
  
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  deletedAt       DateTime?
  
  @@index([assetNumber])
  @@index([tag])
  @@index([serialNumber])
  @@index([status])
}

model AssetAllocation {
  id                String          @id @default(uuid())
  assetId           String
  asset             Asset           @relation(fields: [assetId], references: [id])
  employeeId        String
  employee          Employee        @relation(fields: [employeeId], references: [id])
  allocatedAt       DateTime        @default(now())
  returnedAt        DateTime?
  conditionOnReturn AssetCondition?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  deletedAt         DateTime?
  
  @@index([assetId, returnedAt])
  @@index([employeeId, returnedAt])
  @@unique([assetId], where: { returnedAt: null })
}

model TransferRequest {
  id             String         @id @default(uuid())
  assetId        String
  asset          Asset          @relation(fields: [assetId], references: [id])
  fromEmployeeId String
  fromEmployee   Employee       @relation("TransferFrom", fields: [fromEmployeeId], references: [id])
  toEmployeeId   String
  toEmployee     Employee       @relation("TransferTo", fields: [toEmployeeId], references: [id])
  reason         String?
  status         TransferStatus @default(PENDING)
  approvedAt     DateTime?
  approvedBy     String?
  rejectedAt     DateTime?
  rejectedBy     String?
  rejectionReason String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  deletedAt      DateTime?
  
  @@index([status])
  @@index([fromEmployeeId])
  @@index([toEmployeeId])
  @@index([assetId])
}

model Resource {
  id                 String            @id @default(uuid())
  name               String
  type               String            // e.g., "Conference Room", "Van"
  description        String?
  departmentId       String?
  department         Department?       @relation(fields: [departmentId], references: [id])
  capacity           Int?              // Max concurrent bookings (null = 1)
  isActive           Boolean           @default(true)
  requiresApproval   Boolean           @default(false)
  bookings           ResourceBooking[]
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  deletedAt          DateTime?

  @@index([type])
  @@index([departmentId])
  @@index([isActive])
}

model ResourceBooking {
  id                  String        @id @default(uuid())
  resourceId          String
  resource            Resource      @relation(fields: [resourceId], references: [id])
  employeeId          String
  employee            Employee      @relation(fields: [employeeId], references: [id])
  startTime           DateTime
  endTime             DateTime
  purpose             String?
  status              BookingStatus @default(PENDING)
  approvedBy          String?
  approvedAt          DateTime?
  cancelledBy         String?
  cancelledAt         DateTime?
  cancellationReason  String?
  createdBy           String
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
  deletedAt           DateTime?

  @@index([resourceId, status])
  @@index([employeeId])
  @@index([startTime, endTime])
  @@index([status])
}

model MaintenanceRequest {
  id           String              @id @default(uuid())
  assetId      String
  asset        Asset               @relation(fields: [assetId], references: [id])
  issue        String
  status       MaintenanceStatus   @default(PENDING)
  priority     MaintenancePriority @default(MEDIUM)
  technicianId String?
  technician   Employee?           @relation("Technician", fields: [technicianId], references: [id])
  resolvedAt   DateTime?
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  deletedAt    DateTime?
}

model AuditCycle {
  id           String      @id @default(uuid())
  name         String
  departmentId String
  department   Department  @relation(fields: [departmentId], references: [id])
  startDate    DateTime
  endDate      DateTime
  isClosed     Boolean     @default(false)
  auditorNames String
  items        AuditItem[]
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  deletedAt    DateTime?
}

model AuditItem {
  id               String            @id @default(uuid())
  auditCycleId     String
  auditCycle       AuditCycle        @relation(fields: [auditCycleId], references: [id])
  assetId          String
  asset            Asset             @relation(fields: [assetId], references: [id])
  expectedLocation String
  verification     AuditVerification
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  deletedAt        DateTime?
}

model ActivityLog {
  id         String    @id @default(uuid())
  action     String
  details    String?
  entityId   String?
  entityType String?
  userId     String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  deletedAt  DateTime?
}

model Notification {
  id        String           @id @default(uuid())
  type      NotificationType
  message   String
  isRead    Boolean          @default(false)
  userId    String?
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  deletedAt DateTime?
}

model Location {
  id        String    @id @default(uuid())
  name      String    @unique
  address   String?
  assets    Asset[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
}

model OrganizationSettings {
  id          String   @id @default("default")
  companyName String
  currency    String   @default("USD")
  timezone    String   @default("UTC")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?
}

// ===== ASSET REGISTRY EXTENSIONS =====

model AssetImage {
  id        String   @id @default(uuid())
  assetId   String
  asset     Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)
  url       String   // File path or URL
  filename  String
  mimeType  String
  size      Int      // bytes
  isPrimary Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?
  
  @@index([assetId])
}

model AssetDocument {
  id           String   @id @default(uuid())
  assetId      String
  asset        Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)
  url          String
  filename     String
  mimeType     String
  size         Int
  documentType String   // 'MANUAL', 'WARRANTY', 'INVOICE', 'OTHER'
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  deletedAt    DateTime?
  
  @@index([assetId])
}

model AssetTimeline {
  id          String   @id @default(uuid())
  assetId     String
  asset       Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)
  event       String   // ASSET_REGISTERED, IMAGE_UPLOADED, DOCUMENT_UPLOADED, etc.
  description String
  details     Json?    // Store structured change data
  performedBy String?  // userId
  createdAt   DateTime @default(now())
  
  @@index([assetId])
  @@index([assetId, createdAt])
}
